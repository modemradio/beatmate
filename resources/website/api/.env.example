# ============================================================
# BeatMate V11 - License Server Configuration
# ============================================================
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Flask ---
# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(64))")
SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# Environment: "production" or "development"
# development mode enables /api/test-generate endpoint
FLASK_ENV=development

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- PayPal ---
# Get these from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
PAYPAL_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# "sandbox" or "live"
PAYPAL_MODE=sandbox

# --- SMTP (email sending) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@beatmate.app
SMTP_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://beatmate.app,https://www.beatmate.app

# --- Database ---
# Path to SQLite database file (relative to server.py)
DATABASE_PATH=licenses.db

# --- Rate Limiting ---
# Storage URI for rate limiter (use redis:// in production)
RATELIMIT_STORAGE_URI=memory://
